html
  head
    script.
      
      let socket = io();
        let chatForm = document.getElementById('chat-form');
        let chatInput = document.getElementById('chat-text');
      
        chatForm.addEventListener('submit', function(e) {
          e.preventDefault();
          if (chatInput.value) {
            socket.emit('chat message', chatInput.value);
            chatInput.value = '';
          }
        });
      
  body
