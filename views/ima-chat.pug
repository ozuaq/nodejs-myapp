extends base

block css 
  link(rel='stylesheet', href='/stylesheets/scroll-container.css')

block content
  h1 今だけチャット
  h5
    span(id="userName")= userName
    | さん

    span(id="roomName")= roomName
    | へようこそ！

  .chat.bg-white.p-4.border.border-dark#messagesBox
    
  form.my-3
    .row
      .col-10
        // label.form-label(for='exampleFormControlTextarea1')
        textarea.form-control#chat-text(rows='3')
      .col-2
        button.btn.btn-primary.mb-3#chat-form(type='button' onclick='sendChat()') post 

block script 
  script(src='/socket.io/socket.io.js')
  script(src='/javascripts/ima-chat.js')
